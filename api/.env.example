PORT=3001

# Database (for Prisma later; safe to define now)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=desafio_terrand
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Example Prisma URL format (do not commit real secrets)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/desafio_terrand?schema=public"

# Auth (JWT in httpOnly cookie)
JWT_SECRET=change-me-in-dev
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE_MS=604800000

# Frontend origin (CORS + credentials)
WEB_ORIGIN=http://localhost:3000

